@model ForgotPasswordViewModel
@{ ViewData["Title"] = "Восстановление пароля"; }
 <link rel="icon" href="~/f.png" alt="иконка">
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4 mt-5">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-mortarboard-fill display-4 text-primary"></i>
                    <h3 class="fw-bold mt-2">Восстановление пароля</h3>
                </div>

                <ul class="nav nav-pills nav-fill mb-4">
                    <li class="nav-item"><a class="nav-link" href="/Account/Login">Вход</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Account/Register">Регистрация</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Account/ForgotPassword">Пароль</a></li>
                </ul>

                <p class="text-muted small mb-4">Введите email, и мы отправим инструкцию по сбросу пароля.</p>

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-send me-1"></i>Отправить
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
