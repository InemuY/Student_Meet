@{ ViewData["Title"] = "Письмо отправлено"; }
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4 mt-5">
            <div class="card-body p-5 text-center">
                <i class="bi bi-envelope-check display-4 text-success"></i>
                <h4 class="fw-bold mt-3">Письмо отправлено</h4>
                <p class="text-muted">@ViewBag.Message</p>
                <a href="/Account/Login" class="btn btn-primary">Вернуться ко входу</a>
            </div>
        </div>
    </div>
</div>
