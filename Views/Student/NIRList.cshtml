@model NIRListViewModel
@{ ViewData["Title"] = "Все Мероприятия"; }
<link rel="icon" href="~/f.png" alt="иконка">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Доступные Мероприятия</h4>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Мой профиль
    </a>
</div>

@if (!Model.NIRs.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-journal-x display-4 opacity-25"></i>
        <p class="mt-3">Мероприятия пока нет</p>
    </div>
}

<div class="row g-4">
    @foreach (var nir in Model.NIRs)
    {
        var isJoined = Model.JoinedNIRIds.Contains(nir.Id);
        var isFull = nir.Participants.Count >= nir.MaxParticipants;
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="fw-bold mb-0">@nir.Title</h6>
                        @if (nir.IsOpen && !isFull) { <span class="badge bg-success">Открыта</span> }
                        else if (isFull) { <span class="badge bg-warning">Мест нет</span> }
                        else { <span class="badge bg-secondary">Закрыта</span> }
                    </div>

                    @if (!string.IsNullOrEmpty(nir.Direction))
                    {
                        <span class="badge bg-primary-subtle text-primary mb-2">@nir.Direction</span>
                    }

                    <p class="text-muted small">@(nir.Description ?? "Описание не указано")</p>
                    <p class="small mb-1"><i class="bi bi-person-workspace me-1 text-muted"></i>@nir.Teacher.User.FullName</p>
                    <p class="small mb-3">
                        <i class="bi bi-people me-1 text-muted"></i>
                        @nir.Participants.Count / @nir.MaxParticipants участников
                    </p>

                    @if (isJoined)
                    {
                        <button class="btn btn-success btn-sm w-100" disabled>
                            <i class="bi bi-check-circle me-1"></i>Вы записаны
                        </button>
                    }
                    else if (!nir.IsOpen || isFull)
                    {
                        <button class="btn btn-secondary btn-sm w-100" disabled>
                            <i class="bi bi-lock me-1"></i>Недоступно
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary btn-sm w-100"
                                onclick="openJoinModal(@nir.Id, '@Html.Raw(nir.Title.Replace("'", "\\'"))')">
                            <i class="bi bi-plus-circle me-1"></i>Записаться
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Модальное окно подачи заявки -->
<div class="modal fade" id="joinModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-journal-plus me-2 text-primary"></i>Подача заявки
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="JoinNIR" method="post" enctype="multipart/form-data" id="joinForm">
                <div class="modal-body">
                    <input type="hidden" name="nirId" id="joinNirId" />

                    <p class="mb-3">Мероприятия: <strong id="joinNirTitle"></strong></p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Прикрепить файл заявки
                            <span class="text-muted fw-normal">(необязательно)</span>
                        </label>
                        <div class="border rounded-3 p-3 text-center" id="dropZone"
                             style="cursor:pointer; border-style:dashed !important; transition: background 0.2s">
                            <i class="bi bi-cloud-upload fs-3 text-muted"></i>
                            <p class="text-muted small mb-1 mt-1">Перетащите файл или нажмите для выбора</p>
                            <p class="text-muted" style="font-size:11px">PDF, DOC, DOCX, TXT, JPG, PNG · до 10 МБ</p>
                            <input type="file" name="applicationFile" id="applicationFile"
                                   accept=".pdf,.doc,.docx,.txt,.jpg,.jpeg,.png" class="d-none" />
                        </div>
                        <!-- Выбранный файл -->
                        <div id="filePreview" class="d-none mt-2 p-2 bg-light rounded-3 d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-text text-primary fs-5"></i>
                            <span id="fileName" class="small flex-grow-1 text-truncate"></span>
                            <span id="fileSize" class="text-muted small"></span>
                            <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" id="removeFile">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Подать заявку
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    window.openJoinModal = function(nirId, nirTitle) {
        document.getElementById('joinNirId').value = nirId;
        document.getElementById('joinNirTitle').textContent = nirTitle;
        // Сбросить файл
        document.getElementById('applicationFile').value = '';
        document.getElementById('filePreview').classList.add('d-none');
        document.getElementById('dropZone').style.background = '';
        new bootstrap.Modal(document.getElementById('joinModal')).show();
    };

    // Клик по зоне — открыть файловый диалог
    document.getElementById('dropZone').addEventListener('click', function () {
        document.getElementById('applicationFile').click();
    });

    // Выбор файла
    document.getElementById('applicationFile').addEventListener('change', function () {
        showFile(this.files[0]);
    });

    // Drag & Drop
    var dropZone = document.getElementById('dropZone');
    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        this.style.background = '#e8f4ff';
    });
    dropZone.addEventListener('dragleave', function () {
        this.style.background = '';
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        this.style.background = '';
        var file = e.dataTransfer.files[0];
        if (file) {
            document.getElementById('applicationFile').files = e.dataTransfer.files;
            showFile(file);
        }
    });

    // Удалить файл
    document.getElementById('removeFile').addEventListener('click', function (e) {
        e.stopPropagation();
        document.getElementById('applicationFile').value = '';
        document.getElementById('filePreview').classList.add('d-none');
        document.getElementById('dropZone').style.background = '';
    });

    function showFile(file) {
        if (!file) return;
        var allowed = ['.pdf','.doc','.docx','.txt','.jpg','.jpeg','.png'];
        var ext = '.' + file.name.split('.').pop().toLowerCase();
        if (!allowed.includes(ext)) {
            alert('Недопустимый формат файла.');
            document.getElementById('applicationFile').value = '';
            return;
        }
        if (file.size > 10 * 1024 * 1024) {
            alert('Файл слишком большой. Максимум — 10 МБ.');
            document.getElementById('applicationFile').value = '';
            return;
        }
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(0) + ' КБ';
        document.getElementById('filePreview').classList.remove('d-none');
        document.getElementById('dropZone').style.background = '#f0fff4';
    }
});
</script>
}
