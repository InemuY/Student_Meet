@model TeacherStudentsViewModel
@{ ViewData["Title"] = "Мои студенты"; }
<link rel="icon" href="~/f.png" alt="иконка">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-success"></i>Студенты в моих НИР</h4>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Мой профиль
    </a>
</div>

<!-- Search and Filters -->
<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body p-4">
        <form method="get" asp-action="Students">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control" placeholder="Поиск по ФИО..." value="@Model.SearchQuery" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="nirFilter" class="form-select">
                        <option value="">Все НИР</option>
                        @foreach (var nir in Model.TeacherNIRs)
                        {
                            <option value="@nir.Id" selected="@(Model.FilterNIR == nir.Id.ToString())">@nir.Title</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="statusFilter" class="form-select">
                        <option value="">Все статусы</option>
                        <option value="Pending" selected="@(Model.FilterStatus == "Pending")">На рассмотрении</option>
                        <option value="Approved" selected="@(Model.FilterStatus == "Approved")">Одобрено</option>
                        <option value="Rejected" selected="@(Model.FilterStatus == "Rejected")">Отклонено</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-funnel me-1"></i>Фильтр
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Participants.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-people display-4 opacity-25"></i>
        <p class="mt-3">Студенты не найдены</p>
    </div>
}
else
{
    <div class="card shadow-sm border-0 rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Студент</th>
                        <th>НИР</th>
                        <th>Дата записи</th>
                        <th>Статус</th>
                        <th class="pe-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Participants)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(p.Student.User.PhotoPath))
                                    { <img src="@p.Student.User.PhotoPath" class="rounded-circle me-2" width="36" height="36" style="object-fit:cover" /> }
                                else
                                    { <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center me-2" style="width:36px;height:36px;vertical-align:middle"><i class="bi bi-person-fill text-white small"></i></div> }
                                <div class="d-inline-block">
                                    <div class="fw-semibold">@p.Student.User.FullName</div>
                                    <div class="text-muted small">@p.Student.Course курс, @(p.Student.Group ?? "—")</div>
                                </div>
                            </td>
                            <td><span class="text-muted small">@p.NIR.Title</span></td>
                            <td class="text-muted small">@p.JoinedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                @{
                                    var badge = p.Status switch { "Approved" => "bg-success", "Rejected" => "bg-danger", _ => "bg-warning" };
                                    var label = p.Status switch { "Approved" => "Одобрено", "Rejected" => "Отклонено", _ => "На рассмотрении" };
                                }
                                <span class="badge @badge">@label</span>
                            </td>
                            <td class="pe-4">
                                <!-- Файл заявки -->
                                @if (!string.IsNullOrEmpty(p.ApplicationFilePath))
                                {
                                    <a href="@p.ApplicationFilePath" target="_blank"
                                       class="btn btn-outline-secondary btn-sm me-1"
                                       title="Просмотреть файл заявки: @p.ApplicationFileName">
                                        <i class="bi bi-file-earmark-text me-1"></i>Заявка
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small me-2"><i class="bi bi-file-earmark-x me-1"></i>Без файла</span>
                                }
                                <!-- Одобрить / Отклонить -->
                                @if (p.Status != "Approved")
                                {
                                    <form asp-action="UpdateParticipantStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="status" value="Approved" />
                                        <button type="submit" class="btn btn-outline-success btn-sm" title="Одобрить">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                }
                                @if (p.Status != "Rejected")
                                {
                                    <form asp-action="UpdateParticipantStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Отклонить">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="text-muted small mt-2 ps-1">Найдено: @Model.Participants.Count студентов</div>
}
